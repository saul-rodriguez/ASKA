				<extensions>
					<extension>Parasitics
						<callback>_parSetupDBExtensionCB</callback>
						<iconvalue></iconvalue>
						<icontype></icontype>
					</extension>
				</extensions>
				<currentmode>Single Run, Sweeps and Corners</currentmode>
				<overwritehistory>0</overwritehistory>
				<tests>
					<test enabled="1">Corner_Sim
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>current_source_gm_tb</value>
							</option>
							<option>lib
								<value>CURRENT_SOURCE</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>Corner_Sim_none_Interactive.90</value>
							</option>
						</tooloptions>
						<origoptions>
							<option>cell
								<value>current_source_gm_tb</value>
							</option>
							<option>lib
								<value>CURRENT_SOURCE</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
						</origoptions>
						<outputs>
							<output>DC_GAIN
								<evalType>point</evalType>
							</output>
							<output>PSRR
								<evalType>point</evalType>
							</output>
						</outputs>
					</test>
					<test enabled="1">Montecarlo_Sim
						<tool>ADE</tool>
						<outputs>
							<output>DC_GAIN
								<evalType>point</evalType>
							</output>
							<output>PSRR
								<evalType>point</evalType>
							</output>
							<output>Hist_1mA
								<evalType>point</evalType>
							</output>
							<output>Hist_50mA
								<evalType>point</evalType>
							</output>
						</outputs>
						<tooloptions>
							<option>cell
								<value>current_source_gm_tb</value>
							</option>
							<option>lib
								<value>CURRENT_SOURCE</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>Montecarlo_Sim_CURRENT_SOURCE:current_source_gm_tb:1:1_state_Interactive.90</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
						</tooloptions>
						<prerunscript>0</prerunscript>
						<origoptions>
							<option>cell
								<value>current_source_gm_tb</value>
							</option>
							<option>lib
								<value>CURRENT_SOURCE</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>CURRENT_SOURCE:current_source_gm_tb:1:1_state</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
						</origoptions>
					</test>
				</tests>
				<vars>
					<var>VDD
						<value>3.3</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
							<dependentTest enabled="1">Corner_Sim</dependentTest>
						</dependentTests>
					</var>
					<var>VDD_AC
						<value>0</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
							<dependentTest enabled="1">Corner_Sim</dependentTest>
						</dependentTests>
					</var>
					<var>VDDH
						<value>40</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
							<dependentTest enabled="1">Corner_Sim</dependentTest>
						</dependentTests>
					</var>
					<var>VIN_AC
						<value>1</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
							<dependentTest enabled="1">Corner_Sim</dependentTest>
						</dependentTests>
					</var>
					<var>VIN_DC
						<value>330m</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
							<dependentTest enabled="1">Corner_Sim</dependentTest>
						</dependentTests>
					</var>
					<var>VIN_STEP
						<value>0</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
							<dependentTest enabled="1">Corner_Sim</dependentTest>
						</dependentTests>
					</var>
					<var>VDD_STEP
						<value>100m</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
							<dependentTest enabled="1">Corner_Sim</dependentTest>
						</dependentTests>
					</var>
					<var>VDDH_STEP
						<value>0</value>
						<dependentTests>
							<dependentTest enabled="1">Montecarlo_Sim</dependentTest>
