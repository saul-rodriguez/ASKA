				<tests>
					<test enabled="1">Corner_Sim
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>current_source_gm_tb</value>
							</option>
							<option>lib
								<value>CURRENT_SOURCE</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>Corner_Sim_none_Interactive.219</value>
							</option>
						</tooloptions>
						<origoptions>
							<option>cell
								<value>current_source_gm_tb</value>
							</option>
							<option>lib
								<value>CURRENT_SOURCE</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>schematic</value>
							</option>
						</origoptions>
