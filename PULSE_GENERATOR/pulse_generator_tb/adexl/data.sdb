				<vars>
					<var>VDD3
						<value>3.3</value>
						<dependentTests>
							<dependentTest omitted="0">PULSE_GENERATOR:pulse_generator_tb:1</dependentTest>
							<dependentTest enabled="1">Montecarlo</dependentTest>
						</dependentTests>
					</var>
					<var>VDD3_PULSE
						<value>0</value>
						<dependentTests>
							<dependentTest omitted="0">PULSE_GENERATOR:pulse_generator_tb:1</dependentTest>
							<dependentTest enabled="1">Montecarlo</dependentTest>
						</dependentTests>
					</var>
					<var>VDDHV
						<value>0</value>
