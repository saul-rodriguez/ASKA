				<overwritehistory>0</overwritehistory>
				<tests>
					<test enabled="1">Corner
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>por_tb</value>
							</option>
							<option>lib
								<value>POR</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>Corner_none_MonteCarlo.5</value>
							</option>
						</tooloptions>
						<origoptions>
							<option>cell
								<value>por_tb</value>
							</option>
							<option>lib
								<value>POR</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</origoptions>
					</test>
					<test enabled="1">Montecarlo
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>por_tb</value>
							</option>
							<option>lib
								<value>POR</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>Montecarlo_Corner:1_state_MonteCarlo.5</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</tooloptions>
						<prerunscript>0</prerunscript>
						<origoptions>
							<option>cell
								<value>por_tb</value>
							</option>
							<option>lib
								<value>POR</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>Corner:1_state</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</origoptions>
					</test>
				</tests>
				<vars>
					<var>VDD3
						<value>0</value>
						<dependentTests>
							<dependentTest enabled="1">Corner</dependentTest>
							<dependentTest enabled="1">Montecarlo</dependentTest>
						</dependentTests>
					</var>
					<var>VDD_PULSE
						<value>3.3</value>
						<dependentTests>
							<dependentTest enabled="1">Corner</dependentTest>
							<dependentTest enabled="1">Montecarlo</dependentTest>
						</dependentTests>
					</var>
					<var>VDD_RT
						<value>100u</value>
						<dependentTests>
							<dependentTest enabled="1">Corner</dependentTest>
							<dependentTest enabled="1">Montecarlo</dependentTest>
						</dependentTests>
					</var>
					<var>VDD_BOR
						<value>-0.375</value>
						<dependentTests>
							<dependentTest enabled="1">Corner</dependentTest>
							<dependentTest enabled="1">Montecarlo</dependentTest>
						</dependentTests>
					</var>
				</vars>
				<overwritehistoryname>Interactive.0</overwritehistoryname>
				<plottingoptions>
					<plottingoption>plottingmode
						<value>New Win</value>
					</plottingoption>
					<plottingoption>plottype
						<value>None</value>
