				<tests>
					<test enabled="1">PULSE_GENERATOR:pulse_generator_tb:1
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>pulse_generator_tb</value>
							</option>
							<option>lib
								<value>PULSE_GENERATOR</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>PULSE_GENERATOR:pulse_generator_tb:1_none_Interactive.85</value>
							</option>
						</tooloptions>
						<origoptions>
							<option>cell
								<value>pulse_generator_tb</value>
							</option>
							<option>lib
								<value>PULSE_GENERATOR</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</origoptions>
					</test>
				</tests>
				<vars>
					<var>VDD3
						<value>3.3</value>
						<dependentTests>
							<dependentTest omitted="0">PULSE_GENERATOR:pulse_generator_tb:1</dependentTest>
						</dependentTests>
					</var>
					<var>VDD3_PULSE
						<value>0</value>
						<dependentTests>
							<dependentTest omitted="0">PULSE_GENERATOR:pulse_generator_tb:1</dependentTest>
						</dependentTests>
					</var>
					<var>VDDHV
						<value>40</value>
						<dependentTests>
							<dependentTest omitted="0">PULSE_GENERATOR:pulse_generator_tb:1</dependentTest>
						</dependentTests>
					</var>
					<var>VDDHV_PULSE
						<value>0</value>
						<dependentTests>
