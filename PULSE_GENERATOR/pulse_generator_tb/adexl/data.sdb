				<tests>
					<test enabled="1">PULSE_GENERATOR:pulse_generator_tb:1
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>pulse_generator_tb</value>
							</option>
							<option>lib
								<value>PULSE_GENERATOR</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
