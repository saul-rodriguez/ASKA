				<overwritehistory>0</overwritehistory>
				<tests>
					<test enabled="1">ASKA_TOP:aska_core_tb:1
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>aska_core_tb</value>
							</option>
							<option>lib
								<value>ASKA_TOP</value>
							</option>
							<option>sim
								<value>ams</value>
							</option>
							<option>view
								<value>config_an_schem_dig_fun</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>ASKA_TOP:aska_core_tb:1_none_Interactive.201</value>
							</option>
						</tooloptions>
						<origoptions>
							<option>cell
								<value>aska_core_tb</value>
							</option>
							<option>lib
								<value>ASKA_TOP</value>
							</option>
							<option>sim
								<value>ams</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</origoptions>
						<outputs>
							<output>(VT("/ELE&lt;0&gt;") - VT("/A"))
								<evalType>point</evalType>
							</output>
							<output>((VT("/ELE&lt;0&gt;") - VT("/A")) / 100)
								<evalType>point</evalType>
							</output>
