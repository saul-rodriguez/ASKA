						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>pulse_generator_tb</value>
							</option>
							<option>lib
								<value>PULSE_GENERATOR</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>Montecarlo_PULSE_GENERATOR:pulse_generator_tb:1:1_state_Interactive.224</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</tooloptions>
						<prerunscript>0</prerunscript>
						<origoptions>
							<option>cell
								<value>pulse_generator_tb</value>
							</option>
							<option>lib
								<value>PULSE_GENERATOR</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>PULSE_GENERATOR:pulse_generator_tb:1:1_state</value>
							</option>
							<option>view
								<value>config</value>
							</option>
