				<vars>
					<var>RES
						<value>100</value>
						<dependentTests>
							<dependentTest enabled="1">oss</dependentTest>
							<dependentTest enabled="1">DC</dependentTest>
							<dependentTest enabled="1">ASKA_TOP:aska_core_tb:1</dependentTest>
						</dependentTests>
