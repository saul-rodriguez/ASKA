				<tests>
					<test enabled="1">CONSTANT_GM:constant_gm_tb:1
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>constant_gm_tb</value>
							</option>
							<option>lib
								<value>CONSTANT_GM</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>state
								<value>CONSTANT_GM:constant_gm_tb:1_none_Interactive.28</value>
							</option>
						</tooloptions>
						<origoptions>
							<option>cell
								<value>constant_gm_tb</value>
							</option>
							<option>lib
								<value>CONSTANT_GM</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</origoptions>
						<outputs>
							<output>IDC("/I0/M7/D")
								<evalType>point</evalType>
							</output>
						</outputs>
					</test>
					<test enabled="1">Montecarlo
						<tool>ADE</tool>
						<outputs>
							<output>IDC("/I0/M7/D")
								<evalType>point</evalType>
							</output>
						</outputs>
						<tooloptions>
							<option>cell
								<value>constant_gm_tb</value>
							</option>
							<option>lib
								<value>CONSTANT_GM</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>Montecarlo_CONSTANT_GM:constant_gm_tb:1:1_state_Interactive.28</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</tooloptions>
						<prerunscript>0</prerunscript>
						<origoptions>
							<option>cell
								<value>constant_gm_tb</value>
							</option>
							<option>lib
								<value>CONSTANT_GM</value>
							</option>
							<option>path
								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>CONSTANT_GM:constant_gm_tb:1:1_state</value>
							</option>
							<option>view
								<value>config</value>
							</option>
						</origoptions>
					</test>
				</tests>
				<vars>
					<var>VDD3
						<value>3.3</value>
						<dependentTests>
							<dependentTest enabled="1">CONSTANT_GM:constant_gm_tb:1</dependentTest>
							<dependentTest enabled="1">Montecarlo</dependentTest>
						</dependentTests>
					</var>
					<var>VDD_PULSE
						<value>100m</value>
