				<tests>
					<test enabled="1">HVSWITCH:hvswitch_tb:1
						<tool>ADE</tool>
						<tooloptions>
							<option>cell
								<value>hvswitch_tb</value>
							</option>
							<option>lib
								<value>HVSWITCH</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>view
								<value>config</value>
							</option>
