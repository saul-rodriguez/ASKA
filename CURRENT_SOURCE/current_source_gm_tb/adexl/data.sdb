					<dependentTest omitted="0">Corner_Sim</dependentTest>
					<dependentTest omitted="0">Montecarlo_Sim</dependentTest>
				</dependentTests>
			</var>
			<var>ENABLE_STEP
				<value>-3.3</value>
				<dependentTests>
					<dependentTest omitted="0">Corner_Sim</dependentTest>
					<dependentTest omitted="0">Montecarlo_Sim</dependentTest>
				</dependentTests>
