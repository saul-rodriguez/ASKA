							<dependentTest enabled="1">Montecarlo_sim</dependentTest>
						</dependentTests>
					</var>
					<var>VREF
						<value>1.21</value>
						<dependentTests>
							<dependentTest enabled="1">Corner_sim</dependentTest>
							<dependentTest enabled="1">Montecarlo_sim</dependentTest>
						</dependentTests>
					</var>
					<var>VREF_PULSE
						<value>0.1</value>
