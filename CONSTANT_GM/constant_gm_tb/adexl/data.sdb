								<value>$AXL_SETUPDB_DIR/test_states</value>
							</option>
							<option>sim
								<value>spectre</value>
							</option>
							<option>state
								<value>Montecarlo_CONSTANT_GM:constant_gm_tb:1:1_state_Interactive.97</value>
